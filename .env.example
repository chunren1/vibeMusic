# ========================================
# vibeMusic 环境变量配置 (本地开发)
# ========================================
# 使用方法:
#   Windows (PowerShell): 复制为 .env，手动 source 或通过 IDE 注入
#   Docker Compose: 复制为 .env，docker-compose 自动加载
# ========================================

# 数据库
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ES_URI=http://localhost:9201

# MinIO / RustFS 对象存储
RUSTFS_ENDPOINT=http://127.0.0.1:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# JWT 密钥 (生产环境请更换为强随机字符串)
JWT_SECRET=SyQ8bG9uZ1NlY3JldEtleUZvclZpYmVNdXNpY1Byb2plY3QyMDI2

# 网易云 API 代理
MUSICAPI_URL=http://localhost:3000

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
