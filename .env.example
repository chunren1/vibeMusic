# ========================================
# vibeMusic 环境变量配置模板
# ========================================
# 使用方法: 复制为 .env 并填入真实值
#   cp .env.example .env
# ========================================

# 数据库
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=your-db-password-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ES_URI=http://localhost:9201

# MinIO / RustFS 对象存储
RUSTFS_ENDPOINT=http://127.0.0.1:9000
RUSTFS_ACCESS_KEY=your-rustfs-access-key
RUSTFS_SECRET_KEY=your-rustfs-secret-key

# JWT 密钥 (生产环境请用强随机字符串，如 openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-change-me

# 网易云 API 代理
MUSICAPI_URL=http://localhost:3000

# AI 助手 (SiliconFlow / 其他兼容 OpenAI 格式的 API)
AI_API_KEY=your-ai-api-key-here

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
