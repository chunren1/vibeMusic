# vibeMusic 前端环境变量
# 复制此文件为 .env.production 并填写实际值

# 生产/APK 构建时的后端 API 地址（含 https:// 前缀）
# 本地开发无需配置，使用 Vite proxy 代理到 localhost:8080
VITE_API_HOST=https://your-domain.cpolar.top

# Sentry 错误监控 DSN（可选，用于线上 JS 错误追踪）
# 注册 https://sentry.io → 新建 Vue 项目 → 获取 DSN
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
