{
  "name": "vibemusic",
  "version": "1.0.0",
  "private": true,
  "description": "vibeMusic 全栈音乐项目 - 工作区根配置",
  "scripts": {
    "dev": "concurrently -n musicapi,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd musicapi && node server.js",
    "dev:web": "cd vibemusic-web && npm run dev",
    "build": "cd vibemusic-web && npm run build",
    "deploy:web": "npm run build && echo '前端已更新，Nginx 已生效（挂载 dist/ 目录）'",
    "ops": "node scripts/ops.cjs",
    "tunnel": "start cpolar http 80",
    "tunnel:dev": "start cpolar http 5173",
    "docker:up": "powershell -ExecutionPolicy Bypass -File scripts/docker.ps1 up",
    "docker:down": "powershell -ExecutionPolicy Bypass -File scripts/docker.ps1 down",
    "docker:restart": "powershell -ExecutionPolicy Bypass -File scripts/docker.ps1 restart",
    "docker:status": "powershell -ExecutionPolicy Bypass -File scripts/docker.ps1 status",
    "docker:logs": "powershell -ExecutionPolicy Bypass -File scripts/docker.ps1 logs",
    "nginx:reload": "docker exec vibemusic-nginx nginx -s reload",
    "deploy": "npm run build && npm run docker:up",
    "install:all": "cd musicapi && npm install && cd ../vibemusic-web && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
